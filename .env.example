# BiliLiveNexus 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# --- 基础服务 ---
PORT=5555
DATABASE_URL="file:./data/nexus.db"

# --- 安全认证 ---
# WebUI 管理密码（必填）
NEXUS_PASSWORD=your_admin_password
# JWT 签名密钥（可选，不填则使用 NEXUS_PASSWORD）
JWT_SECRET=
# B站直播 Webhook 验证密钥（可选，设置后请求头须携带 X-Webhook-Secret）
WEBHOOK_SECRET=

# --- NapCat QQ 机器人 ---
BOT_QQ_ID=
NAPCAT_URL=http://localhost:3000
NAPCAT_TOKEN=

# --- 讯飞星火初始配置（可选，部署后可在 WebUI 修改） ---
XF_APPID=
XF_API_SECRET=
XF_API_KEY=
