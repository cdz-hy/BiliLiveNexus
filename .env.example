# =================================================================
# Nexus Core - 环境变量示例文件
# 复制此文件为 .env 并根据实际情况修改
# =================================================================

# [基础服务配置]
PORT=5555
# SQLite 数据库路径 (Prisma 必填)
DATABASE_URL="file:./data/nexus.db"
# Web 管理界面后台密码 (必填，否则界面无法访问)
NEXUS_PASSWORD=your_admin_password

# [NapCat / CQHTTP 配置]
# 机器人 QQ 号 (用于识别 @ 消息)
BOT_QQ_ID=123456789
# NapCat HTTP API 地址 (容器外部访问通常用服务器 IP)
NAPCAT_URL=http://localhost:3000
# NapCat API 鉴权 Token (可选)
NAPCAT_TOKEN=your_token_here

# [AI 初始配置 - 可选]
# 注意：以下配置均可在 WebUI 界面修改，此处的配置仅作为系统首次运行的初始值
# -----------------------------------------------------------------
# 讯飞星火 (Spark)
XF_APPID=
XF_API_SECRET=
XF_API_KEY=

# DeepSeek 
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
